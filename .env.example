# OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional model override
# OPENROUTER_MODEL=anthropic/claude-opus-4

# Tool mode: "mock" or "real"
TOOL_MODE=mock

# Real tool integration endpoints (used when TOOL_MODE=real)
# LEAD_LOOKUP_API_URL=https://your-crm-service.example.com/lead-lookup
# CALENDAR_API_URL=https://your-calendar-service.example.com/availability
# NOTIFICATION_API_URL=https://your-notification-service.example.com/send
# TOOLS_API_TOKEN=your-service-token

# Google + Slack native integrations (used when TOOL_MODE=real and API URLs are not set)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
# GOOGLE_SHEETS_LEADS_RANGE=Leads!A2:H
# GOOGLE_CALENDAR_ID=primary
# Note: for Google Meet creation, this calendar must be writable by the service account.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional company context when TOOL_MODE=real
# COMPANY_NAME=Your Startup
# FOUNDER_NAME=Your Founder Name
# COMPANY_TIMEZONE=Asia/Kolkata
# CALENDAR_BOOKING_LINK=https://cal.com/your-startup/demo

# Optional: Set a custom site URL and app name for OpenRouter rankings
# OPENROUTER_SITE_URL=https://yoursite.com
# OPENROUTER_APP_NAME=startup-ops-agent
